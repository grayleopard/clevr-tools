bg.clevr.tools {
    reverse_proxy localhost:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    request_body {
        max_size 10MB
    }

    log {
        output file /var/log/caddy/bg-api.log
        format json
    }
}
